# BUILD file for fmt library

load("@rules_cc//cc:defs.bzl", "cc_library")

package(default_visibility = ["//visibility:public"])

cc_library(
    name = "fmt",
    srcs = glob(["src/*.cc"]),
    hdrs = glob(["include/fmt/**/*.h"]),
    includes = ["include"],
    strip_include_prefix = "include",
)












