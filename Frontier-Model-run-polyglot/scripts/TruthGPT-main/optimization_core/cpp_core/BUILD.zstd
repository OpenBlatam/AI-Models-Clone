# BUILD file for Zstandard library

load("@rules_cc//cc:defs.bzl", "cc_library")

package(default_visibility = ["//visibility:public"])

cc_library(
    name = "zstd",
    srcs = glob(["lib/**/*.c"]),
    hdrs = glob(["lib/**/*.h"]),
    includes = ["lib"],
    strip_include_prefix = "lib",
)












