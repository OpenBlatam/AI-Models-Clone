# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  Julia Core Module - BUILD                                                   ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

load("@rules_python//python:defs.bzl", "py_library")

package(default_visibility = ["//visibility:public"])

# ═══════════════════════════════════════════════════════════════════════════════
# JULIA MODULE (via genrule)
# ═══════════════════════════════════════════════════════════════════════════════

# Note: Julia doesn't have official Bazel rules
# We'll use genrule to build and package the Julia module

genrule(
    name = "julia_core_pkg",
    srcs = glob(["**/*.jl", "Project.toml"]),
    outs = ["julia_core.tar.gz"],
    cmd = """
        cd $(location :Project.toml)/.. && \
        julia --project=. -e 'using Pkg; Pkg.instantiate()' && \
        tar czf $@ .
    """,
)

py_library(
    name = "julia_core_py",
    srcs = glob(["**/*.py"]),
    data = [":julia_core_pkg"],
)












