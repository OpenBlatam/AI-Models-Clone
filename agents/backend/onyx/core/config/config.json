{
  "system": {
    "name": "Ultra-Modular FastAPI",
    "version": "1.0.0",
    "environment": "development"
  },
  "modules": {
    "enabled": [
      "ai_module",
      "cache_module",
      "microservices_module"
    ],
    "ai_services": {
      "enabled": true,
      "model": "gpt-3.5-turbo",
      "max_tokens": 1000,
      "temperature": 0.7
    },
    "cache_system": {
      "enabled": true,
      "l1_cache": {
        "max_items": 1000,
        "default_ttl": 3600
      },
      "l2_cache": {
        "enabled": false,
        "redis_url": "redis://localhost:6379"
      }
    },
    "microservices": {
      "enabled": true,
      "service_discovery": {
        "enabled": true,
        "consul_host": "localhost",
        "consul_port": 8500
      },
      "circuit_breaker": {
        "enabled": true,
        "failure_threshold": 5,
        "recovery_timeout": 30
      },
      "cache": {
        "enabled": true,
        "default_ttl": 1800
      }
    }
  },
  "logging": {
    "level": "INFO",
    "format": "json",
    "enable_correlation": true
  },
  "performance": {
    "async_workers": 4,
    "connection_timeout": 30,
    "request_timeout": 60
  }
} 