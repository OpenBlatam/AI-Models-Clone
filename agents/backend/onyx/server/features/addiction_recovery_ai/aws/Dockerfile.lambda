# Dockerfile for AWS Lambda deployment
# Optimized for minimal image size and fast cold starts

FROM public.ecr.aws/lambda/python:3.11

# Set working directory
WORKDIR ${LAMBDA_TASK_ROOT}

# Install system dependencies
RUN yum update -y && \
    yum install -y gcc g++ && \
    yum clean all && \
    rm -rf /var/cache/yum

# Copy requirements first for better caching
COPY requirements.txt .

# Install Python dependencies
RUN pip install --no-cache-dir -r requirements.txt && \
    pip install --no-cache-dir mangum aws-xray-sdk boto3

# Copy application code
COPY . .

# Set Lambda handler
ENV LAMBDA_TASK_ROOT=/var/task
ENV LAMBDA_RUNTIME_DIR=/var/runtime

# Optimize Python for Lambda
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1

# Pre-compile Python files
RUN python -m compileall . || true

# Set handler
CMD [ "aws.lambda_handler.lambda_handler" ]










