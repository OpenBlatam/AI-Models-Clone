# BUL API Configuration
# =======================
# Copy this file to .env and configure

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false
LOG_LEVEL=INFO

# Security
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS=*

# Rate Limiting
RATE_LIMIT_PER_MINUTE=10

# Redis Cache (optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_TTL=3600

# Database (optional)
DATABASE_URL=sqlite:///./bul_api.db

# Prometheus
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# Monitoring
MONITORING_ENABLED=true
HEALTH_CHECK_INTERVAL=30

# BUL System
BUL_ENABLED=true
BUL_SIMULATION_MODE=false

# Logging
LOG_FILE=bul_api.log
LOG_JSON=false
LOG_STRUCTURED=false

# OpenTelemetry (optional)
OTEL_ENABLED=false
OTEL_SERVICE_NAME=bul-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Email (for alerts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@bul-api.com

# Webhooks (for alerts)
WEBHOOK_URL=
WEBHOOK_SECRET=



























