# Dockerfile para producción del servicio SEO ultra-optimizado
# Multi-stage build con optimizaciones de seguridad y rendimiento

# =============================================================================
# STAGE 1: Base image con dependencias del sistema
# =============================================================================
FROM python:3.11-slim as base

# Configurar variables de entorno
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    DEBIAN_FRONTEND=noninteractive

# Instalar dependencias del sistema
RUN apt-get update && apt-get install -y \
    # Dependencias básicas
    curl \
    wget \
    gnupg \
    ca-certificates \
    # Dependencias de Chrome
    chromium \
    chromium-driver \
    # Dependencias de compresión
    zstd \
    lz4 \
    # Dependencias de monitoreo
    procps \
    htop \
    # Limpieza
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

# Crear usuario no-root
RUN groupadd -r seo && useradd -r -g seo -s /bin/bash -m seo

# =============================================================================
# STAGE 2: Dependencias Python
# =============================================================================
FROM base as dependencies

# Copiar archivos de dependencias
COPY requirements.ultra_optimized.txt /tmp/requirements.txt

# Instalar dependencias Python
RUN pip install --no-cache-dir -r /tmp/requirements.txt

# =============================================================================
# STAGE 3: Build de la aplicación
# =============================================================================
FROM dependencies as builder

# Crear directorio de trabajo
WORKDIR /app

# Copiar código fuente
COPY . /app/

# Crear directorios necesarios
RUN mkdir -p /app/logs /app/cache /app/temp

# Configurar permisos
RUN chown -R seo:seo /app

# =============================================================================
# STAGE 4: Imagen de producción
# =============================================================================
FROM base as production

# Copiar dependencias Python instaladas
COPY --from=builder /usr/local/lib/python3.11/site-packages /usr/local/lib/python3.11/site-packages
COPY --from=builder /usr/local/bin /usr/local/bin

# Copiar aplicación
COPY --from=builder /app /app

# Cambiar al directorio de trabajo
WORKDIR /app

# Cambiar al usuario no-root
USER seo

# Configurar variables de entorno de producción
ENV ENVIRONMENT=production \
    LOG_LEVEL=INFO \
    WORKERS=4 \
    HOST=0.0.0.0 \
    PORT=8000 \
    MAX_CONNECTIONS=100 \
    CACHE_SIZE=2000 \
    RATE_LIMIT=100

# Configurar límites del sistema
RUN echo "seo soft nofile 65536" >> /etc/security/limits.conf && \
    echo "seo hard nofile 65536" >> /etc/security/limits.conf

# Configurar Chrome para ejecución sin root
ENV CHROME_BIN=/usr/bin/chromium \
    CHROME_PATH=/usr/lib/chromium/ \
    CHROMEDRIVER_PATH=/usr/bin/chromedriver

# Configurar variables de Chrome
ENV CHROME_OPTIONS="--headless --no-sandbox --disable-dev-shm-usage --disable-gpu --disable-extensions --disable-plugins --disable-web-security --disable-features=VizDisplayCompositor --memory-pressure-off --max_old_space_size=4096"

# Configurar logging
ENV LOGURU_LEVEL=INFO \
    LOGURU_FORMAT="{time:YYYY-MM-DD HH:mm:ss} | {level} | {name}:{function}:{line} | {message}"

# Configurar métricas
ENV ENABLE_METRICS=true \
    ENABLE_TRACEMALLOC=true \
    METRICS_PORT=9090

# Configurar caché
ENV CACHE_TYPE=ultra_optimized \
    CACHE_TTL=3600 \
    CACHE_COMPRESSION_LEVEL=3

# Configurar HTTP client
ENV HTTP_RATE_LIMIT=100 \
    HTTP_MAX_CONNECTIONS=100 \
    HTTP_TIMEOUT=10.0

# Configurar parser
ENV PARSER_TYPE=selectolax \
    PARSER_FALLBACK=lxml

# Configurar analyzer
ENV ANALYZER_TYPE=ultra_fast \
    ANALYZER_MODEL=gpt-3.5-turbo \
    ANALYZER_TEMPERATURE=0.1

# Exponer puertos
EXPOSE 8000 9090

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD curl -f http://localhost:8000/health || exit 1

# Comando de inicio
CMD ["python", "main.py", "--mode", "production"]

# =============================================================================
# STAGE 5: Imagen de desarrollo (opcional)
# =============================================================================
FROM dependencies as development

# Crear directorio de trabajo
WORKDIR /app

# Copiar código fuente
COPY . /app/

# Crear directorios necesarios
RUN mkdir -p /app/logs /app/cache /app/temp

# Configurar permisos
RUN chown -R seo:seo /app

# Cambiar al usuario no-root
USER seo

# Configurar variables de entorno de desarrollo
ENV ENVIRONMENT=development \
    LOG_LEVEL=DEBUG \
    WORKERS=1 \
    HOST=0.0.0.0 \
    PORT=8000 \
    RELOAD=true

# Exponer puerto
EXPOSE 8000

# Comando de inicio para desarrollo
CMD ["python", "main.py", "--mode", "development"]

# =============================================================================
# STAGE 6: Imagen de testing
# =============================================================================
FROM dependencies as testing

# Crear directorio de trabajo
WORKDIR /app

# Copiar código fuente
COPY . /app/

# Crear directorios necesarios
RUN mkdir -p /app/logs /app/cache /app/temp /app/tests

# Configurar permisos
RUN chown -R seo:seo /app

# Cambiar al usuario no-root
USER seo

# Configurar variables de entorno de testing
ENV ENVIRONMENT=testing \
    LOG_LEVEL=DEBUG \
    ENABLE_METRICS=false \
    ENABLE_TRACEMALLOC=false

# Instalar dependencias de testing
RUN pip install pytest pytest-asyncio pytest-cov pytest-benchmark

# Comando de inicio para testing
CMD ["python", "main.py", "--mode", "test"]

# =============================================================================
# STAGE 7: Imagen de benchmarking
# =============================================================================
FROM dependencies as benchmark

# Crear directorio de trabajo
WORKDIR /app

# Copiar código fuente
COPY . /app/

# Crear directorios necesarios
RUN mkdir -p /app/logs /app/cache /app/temp /app/benchmarks

# Configurar permisos
RUN chown -R seo:seo /app

# Cambiar al usuario no-root
USER seo

# Configurar variables de entorno de benchmarking
ENV ENVIRONMENT=benchmark \
    LOG_LEVEL=INFO \
    ENABLE_METRICS=true \
    ENABLE_TRACEMALLOC=true

# Comando de inicio para benchmarking
CMD ["python", "main.py", "--mode", "benchmark"]

# =============================================================================
# STAGE 8: Imagen de monitoreo
# =============================================================================
FROM base as monitoring

# Instalar herramientas de monitoreo
RUN apt-get update && apt-get install -y \
    htop \
    iotop \
    nethogs \
    tcpdump \
    netcat \
    && rm -rf /var/lib/apt/lists/*

# Copiar scripts de monitoreo
COPY scripts/monitoring.sh /usr/local/bin/monitoring.sh
RUN chmod +x /usr/local/bin/monitoring.sh

# Comando de monitoreo
CMD ["/usr/local/bin/monitoring.sh"]

# =============================================================================
# STAGE 9: Imagen de debugging
# =============================================================================
FROM dependencies as debug

# Instalar herramientas de debugging
RUN apt-get update && apt-get install -y \
    gdb \
    strace \
    ltrace \
    valgrind \
    && rm -rf /var/lib/apt/lists/*

# Crear directorio de trabajo
WORKDIR /app

# Copiar código fuente
COPY . /app/

# Crear directorios necesarios
RUN mkdir -p /app/logs /app/cache /app/temp /app/debug

# Configurar permisos
RUN chown -R seo:seo /app

# Cambiar al usuario no-root
USER seo

# Configurar variables de entorno de debugging
ENV ENVIRONMENT=debug \
    LOG_LEVEL=DEBUG \
    ENABLE_METRICS=true \
    ENABLE_TRACEMALLOC=true \
    PYTHONPATH=/app

# Comando de debugging
CMD ["python", "-m", "pdb", "main.py", "--mode", "development"] 