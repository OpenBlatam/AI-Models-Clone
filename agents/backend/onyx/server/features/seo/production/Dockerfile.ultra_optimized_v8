# Ultra-Optimized SEO Service Dockerfile v8
# Maximum performance multi-stage build with security hardening

# Build stage with ultra-fast compilation
FROM python:3.11-slim as builder

# Set environment variables for optimization
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV PIP_NO_CACHE_DIR=1
ENV PIP_DISABLE_PIP_VERSION_CHECK=1

# Install system dependencies for ultra-fast builds
RUN apt-get update && apt-get install -y \
    build-essential \
    curl \
    wget \
    git \
    pkg-config \
    libssl-dev \
    libffi-dev \
    libjpeg-dev \
    libpng-dev \
    libxml2-dev \
    libxslt-dev \
    libz-dev \
    libbz2-dev \
    liblzma-dev \
    libsnappy-dev \
    libzstd-dev \
    liblz4-dev \
    libbrotli-dev \
    && rm -rf /var/lib/apt/lists/*

# Create virtual environment
RUN python -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# Upgrade pip and install build tools
RUN pip install --upgrade pip setuptools wheel

# Copy requirements and install dependencies
COPY requirements.ultra_optimized_v8.txt .
RUN pip install --no-cache-dir -r requirements.ultra_optimized_v8.txt

# Install Chrome and ChromeDriver for Selenium
RUN wget -q -O - https://dl.google.com/linux/linux_signing_key.pub | apt-key add - \
    && echo "deb [arch=amd64] http://dl.google.com/linux/chrome/deb/ stable main" >> /etc/apt/sources.list.d/google-chrome.list \
    && apt-get update \
    && apt-get install -y google-chrome-stable \
    && rm -rf /var/lib/apt/lists/*

# Download and install ChromeDriver
RUN CHROME_VERSION=$(google-chrome --version | awk '{print $3}' | awk -F'.' '{print $1}') \
    && wget -q "https://chromedriver.storage.googleapis.com/LATEST_RELEASE_$CHROME_VERSION" -O /tmp/chromedriver_version \
    && CHROMEDRIVER_VERSION=$(cat /tmp/chromedriver_version) \
    && wget -q "https://chromedriver.storage.googleapis.com/$CHROMEDRIVER_VERSION/chromedriver_linux64.zip" -O /tmp/chromedriver.zip \
    && unzip /tmp/chromedriver.zip -d /usr/local/bin/ \
    && chmod +x /usr/local/bin/chromedriver \
    && rm /tmp/chromedriver.zip /tmp/chromedriver_version

# Production stage with minimal footprint
FROM python:3.11-slim as production

# Set environment variables for production
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONPATH=/app
ENV PATH="/opt/venv/bin:$PATH"

# Install runtime dependencies
RUN apt-get update && apt-get install -y \
    curl \
    wget \
    ca-certificates \
    libssl3 \
    libffi8 \
    libjpeg62-turbo \
    libpng16-16 \
    libxml2 \
    libxslt1.1 \
    libz1 \
    libbz2-1.0 \
    liblzma5 \
    libsnappy1v5 \
    libzstd1 \
    liblz4-1 \
    libbrotli1 \
    google-chrome-stable \
    && rm -rf /var/lib/apt/lists/*

# Copy ChromeDriver from builder
COPY --from=builder /usr/local/bin/chromedriver /usr/local/bin/chromedriver

# Create non-root user for security
RUN groupadd -r seo && useradd -r -g seo -m -d /app seo

# Create application directory
WORKDIR /app

# Copy virtual environment from builder
COPY --from=builder /opt/venv /opt/venv

# Copy application code
COPY --chown=seo:seo . .

# Create necessary directories
RUN mkdir -p /app/logs /app/cache /app/temp \
    && chown -R seo:seo /app

# Set system limits for ultra-fast performance
RUN echo "seo soft nofile 131072" >> /etc/security/limits.conf \
    && echo "seo hard nofile 131072" >> /etc/security/limits.conf \
    && echo "seo soft nproc 65536" >> /etc/security/limits.conf \
    && echo "seo hard nproc 65536" >> /etc/security/limits.conf

# Configure sysctl for performance
RUN echo "net.core.somaxconn = 131072" >> /etc/sysctl.conf \
    && echo "net.ipv4.tcp_max_syn_backlog = 131072" >> /etc/sysctl.conf \
    && echo "net.core.netdev_max_backlog = 10000" >> /etc/sysctl.conf \
    && echo "net.ipv4.tcp_fin_timeout = 15" >> /etc/sysctl.conf \
    && echo "net.ipv4.tcp_keepalive_time = 600" >> /etc/sysctl.conf \
    && echo "net.ipv4.tcp_max_tw_buckets = 10000" >> /etc/sysctl.conf

# Switch to non-root user
USER seo

# Set Python optimizations
ENV PYTHONOPTIMIZE=2
ENV PYTHONHASHSEED=random

# Configure Chrome for headless operation
ENV CHROME_BIN=/usr/bin/google-chrome
ENV CHROME_DRIVER=/usr/local/bin/chromedriver
ENV CHROME_HEADLESS=1
ENV CHROME_NO_SANDBOX=1
ENV CHROME_DISABLE_DEV_SHM_USAGE=1

# Health check
HEALTHCHECK --interval=15s --timeout=5s --start-period=30s --retries=3 \
    CMD curl -f http://localhost:8000/health || exit 1

# Expose port
EXPOSE 8000

# Default command
CMD ["python", "main_production_v8.py"]


# Development stage for debugging
FROM production as development

# Install development dependencies
USER root
RUN pip install --no-cache-dir \
    pytest \
    pytest-asyncio \
    pytest-cov \
    black \
    isort \
    flake8 \
    mypy \
    ipython \
    ipdb

# Switch back to seo user
USER seo

# Development command
CMD ["python", "main_production_v8.py", "--reload"]


# Testing stage
FROM production as testing

# Install testing dependencies
USER root
RUN pip install --no-cache-dir \
    pytest \
    pytest-asyncio \
    pytest-cov \
    pytest-mock \
    responses \
    httpx

# Switch back to seo user
USER seo

# Testing command
CMD ["pytest", "-v", "--cov=app", "--cov-report=html", "--cov-report=term"] 