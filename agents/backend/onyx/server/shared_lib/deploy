#!/bin/bash
# Comando Único de Deployment
# ============================
# Uso: ./deploy [tipo] [servicio] [stage] [region]
# Ejemplo: ./deploy lambda mi-servicio prod us-east-1

set -e

# Colores
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
NC='\033[0m'

# Variables con defaults
DEPLOY_TYPE="${1:-lambda}"
SERVICE_NAME="${2:-shared-lib-service}"
STAGE="${3:-dev}"
REGION="${4:-us-east-1}"

echo -e "${BLUE}╔════════════════════════════════════════════╗${NC}"
echo -e "${BLUE}║   🚀 Deployment Automatizado              ║${NC}"
echo -e "${BLUE}╚════════════════════════════════════════════╝${NC}"
echo ""
echo -e "${YELLOW}Tipo: ${DEPLOY_TYPE}${NC}"
echo -e "${YELLOW}Servicio: ${SERVICE_NAME}${NC}"
echo -e "${YELLOW}Stage: ${STAGE}${NC}"
echo -e "${YELLOW}Region: ${REGION}${NC}"
echo ""

# Función para verificar comandos
check_command() {
    if ! command -v $1 &> /dev/null; then
        echo -e "${RED}❌ $2 no está instalado${NC}"
        echo "   Instala con: $3"
        return 1
    fi
    return 0
}

# Verificar prerequisitos
echo -e "${BLUE}🔍 Verificando prerequisitos...${NC}"

# AWS CLI
if ! check_command aws "AWS CLI" "pip install awscli"; then
    exit 1
fi
echo -e "${GREEN}✅ AWS CLI${NC}"

# Credenciales AWS
if ! aws sts get-caller-identity &> /dev/null; then
    echo -e "${RED}❌ AWS credentials no configuradas${NC}"
    echo "   Configura con: aws configure"
    exit 1
fi
echo -e "${GREEN}✅ AWS Credentials${NC}"

# Python
if ! check_command python3 "Python3" "Instala Python 3.11+"; then
    exit 1
fi
echo -e "${GREEN}✅ Python3${NC}"

# Verificaciones específicas por tipo
case $DEPLOY_TYPE in
    lambda)
        if ! check_command serverless "Serverless Framework" "npm install -g serverless"; then
            echo -e "${YELLOW}⚠️  Instalando Serverless Framework...${NC}"
            npm install -g serverless serverless-python-requirements
        fi
        echo -e "${GREEN}✅ Serverless Framework${NC}"
        ;;
    ecs)
        if ! check_command docker "Docker" "Instala Docker Desktop"; then
            exit 1
        fi
        echo -e "${GREEN}✅ Docker${NC}"
        ;;
    *)
        echo -e "${RED}❌ Tipo no válido: ${DEPLOY_TYPE}${NC}"
        echo "   Opciones: lambda, ecs, local"
        exit 1
        ;;
esac

echo ""

# Paso 1: Setup AWS Resources
echo -e "${BLUE}📦 Paso 1/3: Configurando recursos AWS...${NC}"
cd "$(dirname "$0")"
python3 aws/setup_aws.py ${SERVICE_NAME} ${REGION} || {
    echo -e "${YELLOW}⚠️  Algunos recursos pueden ya existir, continuando...${NC}"
}
echo ""

# Paso 2: Build (si es necesario)
if [ "$DEPLOY_TYPE" = "ecs" ]; then
    echo -e "${BLUE}🔨 Paso 2/3: Building Docker image...${NC}"
    docker build -f docker/Dockerfile -t ${SERVICE_NAME}:latest .. || {
        echo -e "${RED}❌ Error en build${NC}"
        exit 1
    }
    echo -e "${GREEN}✅ Build completado${NC}"
    echo ""
fi

# Paso 3: Deploy
echo -e "${BLUE}🚀 Paso 3/3: Deploying...${NC}"
case $DEPLOY_TYPE in
    lambda)
        python3 aws/quick_deploy.py lambda ${SERVICE_NAME} ${STAGE} ${REGION}
        ;;
    ecs)
        python3 aws/quick_deploy.py ecs ${SERVICE_NAME} ${REGION}
        ;;
    local)
        echo -e "${YELLOW}📦 Iniciando servicios locales con Docker Compose...${NC}"
        cd docker
        docker-compose up -d
        echo -e "${GREEN}✅ Servicios iniciados${NC}"
        echo -e "${YELLOW}   API: http://localhost:8030${NC}"
        echo -e "${YELLOW}   Docs: http://localhost:8030/docs${NC}"
        ;;
esac

echo ""
echo -e "${GREEN}╔════════════════════════════════════════════╗${NC}"
echo -e "${GREEN}║   ✅ Deployment Completado                ║${NC}"
echo -e "${GREEN}╚════════════════════════════════════════════╝${NC}"
echo ""

# Mostrar información
if [ "$DEPLOY_TYPE" = "lambda" ]; then
    echo -e "${YELLOW}📊 Información del deployment:${NC}"
    serverless info --stage ${STAGE} 2>/dev/null || echo "   Ejecuta: serverless info --stage ${STAGE}"
elif [ "$DEPLOY_TYPE" = "ecs" ]; then
    echo -e "${YELLOW}📝 Siguiente paso:${NC}"
    echo "   Crea task definition y service en ECS"
    echo "   Ver: aws/AWS_DEPLOYMENT_GUIDE.md"
fi

echo ""
echo -e "${BLUE}📚 Documentación:${NC}"
echo "   - aws/EASY_DEPLOY.md"
echo "   - aws/AWS_DEPLOYMENT_GUIDE.md"
echo ""




