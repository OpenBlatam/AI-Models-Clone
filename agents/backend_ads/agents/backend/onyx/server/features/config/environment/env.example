# Onyx Features - Production Environment Configuration
# Copy this file to .env and update the values for your environment

# =============================================================================
# ENVIRONMENT SETTINGS
# =============================================================================
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
APP_NAME="Onyx Features"
APP_VERSION="1.0.0"
API_PREFIX="/api/v1"

# =============================================================================
# SECURITY SETTINGS
# =============================================================================
# CRITICAL: Change this secret key in production!
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
ENCRYPTION_KEY=your-encryption-key-32-chars-long

# CORS Configuration
ENABLE_CORS=true
ALLOWED_ORIGINS="https://yourdomain.com,https://api.yourdomain.com"

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL Configuration
DATABASE_URL=postgresql://onyx_user:your-db-password@localhost:5432/onyx_db
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
DB_ECHO=false

# Database Credentials (used by docker-compose)
DB_PASSWORD=your-super-secure-db-password

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=your-redis-password
REDIS_SSL=false
REDIS_MAX_CONNECTIONS=20
REDIS_SOCKET_TIMEOUT=30.0

# =============================================================================
# IMAGE PROCESSING SETTINGS
# =============================================================================
IMG_MAX_FILE_SIZE_MB=100
IMG_MAX_VISION_SIZE_MB=20
IMG_MAX_DIMENSION=1024
IMG_JPEG_QUALITY=85
IMG_WEBP_QUALITY=80
IMG_ENABLE_OPTIMIZATION=true
IMG_STRICT_VALIDATION=true
IMG_USE_MAGIC_BYTES=true
IMG_STORAGE_TIMEOUT=30

# =============================================================================
# KEY MESSAGES SETTINGS
# =============================================================================
MSG_MAX_LENGTH=10000
MSG_MAX_BATCH=100
MSG_CACHE_TTL=3600
MSG_DEFAULT_TIMEOUT=30
MSG_ENABLE_COMPRESSION=true
MSG_ENABLE_ENCRYPTION=false

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================
# Prometheus Metrics
MONITORING_PROMETHEUS=true
METRICS_PORT=8000
HEALTH_CHECK_INTERVAL=60

# Sentry Error Tracking
MONITORING_SENTRY=true
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# Grafana Dashboard
GRAFANA_PASSWORD=your-grafana-admin-password

# =============================================================================
# PERFORMANCE SETTINGS
# =============================================================================
ENABLE_ASYNC=true
MAX_WORKERS=4
REQUEST_TIMEOUT=30
MAX_CONCURRENT_REQUESTS=100

# Cache Configuration
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE=1000

# =============================================================================
# PRODUCTION DEPLOYMENT NOTES
# =============================================================================
# - Always use strong passwords in production
# - Rotate secrets regularly
# - Use environment-specific values
# - Enable monitoring in production
# - Set up proper backup strategies
# - Configure SSL/TLS for HTTPS
# - Use a proper secret management system for sensitive data 