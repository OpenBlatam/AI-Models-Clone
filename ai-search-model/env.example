# AI Search Model - Archivo de Configuración de Ejemplo
# Copia este archivo como .env y ajusta los valores según tus necesidades

# ===========================================
# CONFIGURACIÓN DE LA API
# ===========================================
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_WORKERS=1

# ===========================================
# CONFIGURACIÓN DE BASE DE DATOS
# ===========================================
DATABASE_PATH=vector_database.db
EMBEDDINGS_PATH=embeddings.pkl
BACKUP_PATH=backups

# ===========================================
# CONFIGURACIÓN DEL MODELO DE IA
# ===========================================
# Modelo de embeddings (opciones populares):
# - sentence-transformers/all-MiniLM-L6-v2 (recomendado, rápido)
# - sentence-transformers/all-mpnet-base-v2 (mejor calidad)
# - sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2 (multilingüe)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
MAX_QUERY_LENGTH=512
MAX_CONTENT_LENGTH=100000
SNIPPET_LENGTH=200

# ===========================================
# CONFIGURACIÓN DE BÚSQUEDA
# ===========================================
DEFAULT_SEARCH_LIMIT=10
MAX_SEARCH_LIMIT=100
SIMILARITY_THRESHOLD=0.1
SEMANTIC_WEIGHT=0.7
KEYWORD_WEIGHT=0.3

# ===========================================
# CONFIGURACIÓN DE TF-IDF
# ===========================================
TFIDF_MAX_FEATURES=10000
TFIDF_NGRAM_RANGE=(1,2)

# ===========================================
# CONFIGURACIÓN DE LOGGING
# ===========================================
LOG_LEVEL=INFO
LOG_FILE=

# ===========================================
# CONFIGURACIÓN DE CORS
# ===========================================
CORS_ORIGINS=["*"]
CORS_ALLOW_CREDENTIALS=true

# ===========================================
# CONFIGURACIÓN DE CACHE
# ===========================================
ENABLE_CACHE=true
CACHE_TTL=3600

# ===========================================
# CONFIGURACIÓN DE SEGURIDAD
# ===========================================
API_KEY_REQUIRED=false
API_KEY=
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ===========================================
# CONFIGURACIÓN DE PROCESAMIENTO DE DOCUMENTOS
# ===========================================
SUPPORTED_DOCUMENT_TYPES=["text", "markdown", "html", "json", "pdf"]
BATCH_SIZE=100

# ===========================================
# CONFIGURACIÓN DE MONITOREO
# ===========================================
ENABLE_METRICS=true
METRICS_PORT=9090

# ===========================================
# CONFIGURACIÓN DE DESARROLLO
# ===========================================
# Para desarrollo local
DEBUG=true
ENVIRONMENT=development

# ===========================================
# CONFIGURACIÓN DE PRODUCCIÓN
# ===========================================
# Para producción, cambiar estos valores:
# API_RELOAD=false
# LOG_LEVEL=WARNING
# API_KEY_REQUIRED=true
# CORS_ORIGINS=["https://tudominio.com"]
# ENVIRONMENT=production



























