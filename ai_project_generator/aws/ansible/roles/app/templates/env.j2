# AI Project Generator Environment Variables
# Generated by Ansible - DO NOT EDIT MANUALLY

# Environment
ENVIRONMENT={{ environment | default('production') }}
DEBUG={{ debug | default('False') }}

# Application
APP_NAME={{ project_name | default('ai-project-generator') }}
APP_HOST=0.0.0.0
APP_PORT={{ app_port | default(8020) }}

# Redis Configuration
{% if redis_url is defined %}
REDIS_URL={{ redis_url }}
{% else %}
REDIS_URL=redis://localhost:6379
{% endif %}

# MCP Configuration
MCP_SECRET_KEY={{ mcp_secret_key | default('CHANGE_THIS_IN_PRODUCTION') }}
MCP_ENABLE_TRACING={{ mcp_enable_tracing | default('true') }}
MCP_ENABLE_METRICS={{ mcp_enable_metrics | default('true') }}

# OpenTelemetry (optional)
{% if otlp_endpoint is defined %}
OTLP_ENDPOINT={{ otlp_endpoint }}
{% endif %}

# AWS Configuration
AWS_REGION={{ aws_region | default('us-east-1') }}
{% if aws_access_key_id is defined %}
AWS_ACCESS_KEY_ID={{ aws_access_key_id }}
AWS_SECRET_ACCESS_KEY={{ aws_secret_access_key }}
{% endif %}

# Security
SECRET_KEY={{ secret_key | default('CHANGE_THIS_TO_A_SECURE_RANDOM_STRING') }}
ALLOWED_HOSTS={{ allowed_hosts | default('*') }}

# Logging
LOG_LEVEL={{ log_level | default('INFO') }}

# Performance
WORKERS={{ workers | default(4) }}
MAX_WORKERS={{ max_workers | default(8) }}

# Additional variables
{% if additional_env_vars is defined %}
{% for key, value in additional_env_vars.items() %}
{{ key }}={{ value }}
{% endfor %}
{% endif %}

