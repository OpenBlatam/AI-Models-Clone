# AWS Configuration
aws_region = "us-east-1"

# Project Configuration
project_name = "ai-project-generator"
environment  = "production"

# EC2 Configuration
instance_type    = "t3.medium"  # Use t3.large or t3.xlarge for ML workloads
key_name         = "ai-project-generator-key"
enable_public_ip  = true

# Auto Scaling Configuration
min_size         = 1
max_size         = 3
desired_capacity = 2

# Storage Configuration (increase for ML models)
root_volume_size = 50
root_volume_type = "gp3"

# Application Configuration
app_port         = 8020
health_check_path = "/health"

# Redis Configuration
enable_elasticache = false  # Set to true for production
redis_node_type    = "cache.t3.micro"

# Network Configuration
allowed_cidr_blocks = [
  "0.0.0.0/0"  # Restrict this in production to your IP!
]

# Monitoring
enable_monitoring = true

# Additional Tags
tags = {
  Team        = "DevOps"
  CostCenter  = "Engineering"
  Application = "AI Project Generator"
}

