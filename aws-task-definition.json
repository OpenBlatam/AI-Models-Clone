{
  "family": "blatam-academy",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "containerDefinitions": [
    {
      "name": "blatam-academy",
      "image": "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/blatam-academy:latest",
      "portMappings": [
        {
          "containerPort": 3000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "DATABASE_URL",
          "value": "postgresql://neondb_owner:npg_ejg2Yr1EZMOw@ep-dark-sky-a5c88yly-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require"
        },
        {
          "name": "AUTH_SECRET",
          "value": "32mwUMnlOtkH1H8irIqxlaL80KvgdjUlbg2IovnhL1s="
        },
        {
          "name": "GOOGLE_CLIENT_ID",
          "value": "766657034501-2fcprad0507agtsvn5gvgvpv0ggqm80i.apps.googleusercontent.com"
        },
        {
          "name": "GOOGLE_CLIENT_SECRET",
          "value": "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"
        },
        {
          "name": "NEXT_PUBLIC_SITE_URL",
          "value": "https://blatam-academy.${AWS_REGION}.elasticbeanstalk.com"
        },
        {
          "name": "NODE_ENV",
          "value": "production"
        },
        {
          "name": "NEXT_TELEMETRY_DISABLED",
          "value": "1"
        },
        {
          "name": "REDIS_URL",
          "value": "redis://${REDIS_ENDPOINT}:6379"
        },
        {
          "name": "NEXT_PUBLIC_CDN_URL",
          "value": "https://${CLOUDFRONT_DOMAIN}"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/blatam-academy",
          "awslogs-region": "${AWS_REGION}",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:3000/api/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      },
      "ulimits": [
        {
          "name": "nofile",
          "softLimit": 65536,
          "hardLimit": 65536
        }
      ]
    }
  ]
} 