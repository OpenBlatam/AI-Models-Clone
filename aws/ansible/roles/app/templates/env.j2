# Application Environment Variables
# Generated by Ansible - DO NOT EDIT MANUALLY

# Environment
ENVIRONMENT={{ environment | default('production') }}
DEBUG={{ debug | default('False') }}

# Application
APP_NAME={{ project_name | default('blatam-academy') }}
APP_HOST=0.0.0.0
APP_PORT=8000

# Database (if using RDS or external database)
{% if database_url is defined %}
DATABASE_URL={{ database_url }}
{% else %}
DATABASE_URL=postgresql://user:password@localhost:5432/blatam_academy
{% endif %}

# Redis (if using ElastiCache or external Redis)
{% if redis_url is defined %}
REDIS_URL={{ redis_url }}
{% else %}
REDIS_URL=redis://localhost:6379/0
{% endif %}

# AWS Configuration
AWS_REGION={{ aws_region | default('us-east-1') }}
{% if aws_access_key_id is defined %}
AWS_ACCESS_KEY_ID={{ aws_access_key_id }}
AWS_SECRET_ACCESS_KEY={{ aws_secret_access_key }}
{% endif %}

# Security
SECRET_KEY={{ secret_key | default('CHANGE_THIS_IN_PRODUCTION') }}
ALLOWED_HOSTS={{ allowed_hosts | default('*') }}

# Logging
LOG_LEVEL={{ log_level | default('INFO') }}

# Additional variables
{% if additional_env_vars is defined %}
{% for key, value in additional_env_vars.items() %}
{{ key }}={{ value }}
{% endfor %}
{% endif %}

