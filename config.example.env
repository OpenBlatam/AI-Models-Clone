# 🎯 Facebook Posts Configuration
# Copy this file to .env and configure your settings

# === AI PROVIDERS ===
# OpenAI (Primary LLM Provider)
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_ORGANIZATION=org-your-organization-id  # Optional

# Anthropic (Alternative LLM Provider)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Google Search (Optional - for web search tools)
GOOGLE_API_KEY=your-google-api-key
GOOGLE_CSE_ID=your-custom-search-engine-id

# === ONYX INTEGRATION ===
# Onyx Database
ONYX_DB_URL=postgresql://user:password@localhost:5432/onyx_db
ONYX_DB_POOL_SIZE=20
ONYX_DB_MAX_OVERFLOW=10

# Onyx Cache (Redis)
ONYX_CACHE_URL=redis://localhost:6379/0
ONYX_CACHE_TTL=3600
ONYX_CACHE_MAX_CONNECTIONS=20

# Onyx Authentication
ONYX_AUTH_SECRET=your-secret-key-for-jwt
ONYX_AUTH_ALGORITHM=HS256
ONYX_AUTH_EXPIRE_MINUTES=1440

# === LANGCHAIN CONFIGURATION ===
# Model Settings
LANGCHAIN_MODEL_NAME=gpt-3.5-turbo-instruct
LANGCHAIN_CHAT_MODEL=gpt-3.5-turbo
LANGCHAIN_TEMPERATURE=0.7
LANGCHAIN_MAX_TOKENS=1000

# Features
LANGCHAIN_ENABLE_MEMORY=true
LANGCHAIN_ENABLE_TOOLS=true
LANGCHAIN_ENABLE_AGENTS=false
LANGCHAIN_ENABLE_VECTOR_STORE=false
LANGCHAIN_ENABLE_WEB_SEARCH=false

# Performance
LANGCHAIN_CACHE_ENABLED=true
LANGCHAIN_VERBOSE=false
LANGCHAIN_ASYNC_MODE=true

# === FACEBOOK SPECIFIC ===
# API Configuration
FACEBOOK_API_VERSION=v18.0
FACEBOOK_DEFAULT_POST_LENGTH=280
FACEBOOK_MAX_HASHTAGS=5
FACEBOOK_ENABLE_EMOJI=true

# Content Generation
FACEBOOK_GENERATION_RETRIES=2
FACEBOOK_VARIATION_COUNT=2
FACEBOOK_ENABLE_AB_TESTING=true

# Analysis Features
FACEBOOK_ENABLE_SENTIMENT_ANALYSIS=true
FACEBOOK_ENABLE_ENGAGEMENT_PREDICTION=true
FACEBOOK_ENABLE_VIRALITY_SCORING=true

# === PERFORMANCE SETTINGS ===
# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST_SIZE=10

# Timeouts
REQUEST_TIMEOUT_SECONDS=30
LANGCHAIN_TIMEOUT_SECONDS=60
DATABASE_TIMEOUT_SECONDS=10

# Concurrency
MAX_CONCURRENT_REQUESTS=10
MAX_CONCURRENT_GENERATIONS=5
THREAD_POOL_SIZE=20

# === MONITORING & LOGGING ===
# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/facebook_posts.log
LOG_ROTATION=daily
LOG_RETENTION_DAYS=30

# Metrics
ENABLE_METRICS=true
METRICS_PORT=9090
METRICS_PATH=/metrics

# Health Checks
HEALTH_CHECK_INTERVAL=60
HEALTH_CHECK_TIMEOUT=10

# === DEVELOPMENT SETTINGS ===
# Environment
ENVIRONMENT=development
DEBUG=false
TESTING=false

# Development Features
ENABLE_API_DOCS=true
ENABLE_CORS=true
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Hot Reload
RELOAD=true
WORKERS=1

# === PRODUCTION SETTINGS ===
# When ENVIRONMENT=production, uncomment these:
# DEBUG=false
# TESTING=false
# LANGCHAIN_VERBOSE=false
# RELOAD=false
# WORKERS=4
# ENABLE_API_DOCS=false

# Security
# ALLOWED_HOSTS=your-domain.com,api.your-domain.com
# SSL_REDIRECT=true
# SECURE_HEADERS=true

# === OPTIONAL INTEGRATIONS ===
# Sentry (Error Tracking)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# DataDog (Monitoring)
# DATADOG_API_KEY=your-datadog-api-key
# DATADOG_SERVICE_NAME=facebook-posts

# Slack (Notifications)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# === FEATURE FLAGS ===
# Enable/Disable Features
ENABLE_FACEBOOK_API_INTEGRATION=false
ENABLE_POST_SCHEDULING=true
ENABLE_ANALYTICS_TRACKING=true
ENABLE_REAL_TIME_UPDATES=false
ENABLE_MULTI_LANGUAGE=false 