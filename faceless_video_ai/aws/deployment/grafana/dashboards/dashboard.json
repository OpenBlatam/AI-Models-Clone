{
  "dashboard": {
    "title": "Faceless Video AI - Monitoring",
    "tags": ["faceless-video-ai", "production"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "API Request Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(api_requests_total[5m])",
            "legendFormat": "{{method}} {{endpoint}}"
          }
        ]
      },
      {
        "id": 2,
        "title": "Video Generation Success Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(video_generation_total{status=\"success\"}[5m]) / rate(video_generation_total[5m])",
            "legendFormat": "Success Rate"
          }
        ]
      },
      {
        "id": 3,
        "title": "Active Video Generations",
        "type": "graph",
        "targets": [
          {
            "expr": "active_video_generations",
            "legendFormat": "Active"
          }
        ]
      },
      {
        "id": 4,
        "title": "Queue Size",
        "type": "graph",
        "targets": [
          {
            "expr": "video_queue_size",
            "legendFormat": "Queue Size"
          }
        ]
      },
      {
        "id": 5,
        "title": "API Response Time",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, api_request_duration_seconds_bucket)",
            "legendFormat": "95th percentile"
          }
        ]
      },
      {
        "id": 6,
        "title": "Error Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(errors_total[5m])",
            "legendFormat": "{{error_type}}"
          }
        ]
      }
    ],
    "refresh": "10s",
    "schemaVersion": 16,
    "version": 1
  }
}




