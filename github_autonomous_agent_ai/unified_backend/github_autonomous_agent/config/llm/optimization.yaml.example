# Configuración de Optimización
# Caché, retry, rate limiting, etc.

cache:
  enabled: true
  ttl: 3600  # 1 hora en segundos
  max_size: 1000
  strategy: "lru"  # lru, fifo, ttl

retry:
  max_attempts: 3
  min_wait: 1.0  # segundos
  max_wait: 10.0  # segundos
  exponential_base: 2.0
  retry_on:
    - "timeout"
    - "rate_limit"
    - "server_error"
  dont_retry_on:
    - "authentication_error"
    - "authorization_error"
    - "validation_error"

rate_limiting:
  enabled: true
  requests_per_minute: 50
  requests_per_hour: 1000
  requests_per_day: 10000
  strategy: "token_bucket"  # token_bucket, sliding_window

circuit_breaker:
  enabled: true
  failure_threshold: 5
  recovery_timeout: 60  # segundos
  half_open_max_calls: 3

batching:
  enabled: true
  batch_size: 10
  max_wait_time: 0.5  # segundos
  max_parallel_batches: 5

performance:
  connection_pool_size: 100
  max_keepalive_connections: 20
  timeout: 60  # segundos
  connect_timeout: 10  # segundos



