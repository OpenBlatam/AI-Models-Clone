<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta content="IE=edge" http-equiv="X-UA-Compatible" />
    <meta content="width=device-width, initial-scale=1" name="viewport" />
    <title>This isn’t what you wanted to see. | Mailchimp</title>
    <meta content="noindex,nofollow" name="robots" />

    <style type="text/css">
        html, body {
            width: 100%; height: 100%;
            margin: 0; padding: 0;
            box-sizing: border-box;
            background: #f6f6f4;
        }
        .content {
            padding: 20px 20px 80px 20px;
            box-sizing: border-box;
            margin: 0 auto;
            max-width: 480px;
        }
        .lockup {
            max-width: 240px;
            margin-bottom: 80px;
            padding-right: 10%;
            box-sizing: border-box;
        }
        .lockup img {
            width: 100%;
        }
        .h4 {
            font-size: 28px;
            font-weight: 300;
            line-height: 1.1;
            font-family: Georgia, Times, "Times New Roman", serif;;
        }
        .copy {
            font-size: 16px;
            font-weight: 400;
            line-height: 1.5;
            font-family: "Helvetica Neue", Helvetica, Arial, Verdana, sans-serif;
        }
        .monospace {
            font-family: monospace;
        }
    </style>
</head>
<body>
    <div class="content">
        <div class="lockup">
            <a href="/">
                <img src="/static/images/lockup.svg">
            </a>
        </div>
        <h1 class="h4">This isn’t what you wanted to see.</h1>
        <p class="copy">We can’t find the requested URL on our server.</p>
        <p class="copy">Try <a href="/search/">searching</a> or go back to our <a href="/">home page</a>.</p>
    </div>
</body>
</html>
