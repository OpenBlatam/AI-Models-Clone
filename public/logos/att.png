	margin: 5px 0 !important;
	padding-bottom: 5px;
}
.wpp-list.wpp-list-with-thumbnails .wpp-thumbnail {
	float:initial;
}

.wpp-list.wpp-list-with-thumbnails{
	padding-left: 5px;
}

.wpp-list.wpp-list-with-thumbnails li {
    position:relative;
	margin-right: 5px !important;
	border-bottom: 1px #cccccc solid;
	float: left;
    display: flex;
    justify-content: space-between;
    align-items: center;
	width: auto;
	border: 0px;
	border-radius:0px;
	box-shadow: none;
	border-bottom: 1px #cccccc solid;
}

.wpp-list.wpp-list-with-thumbnails li:last-child{
	border: 0px;
}

.wpp-list.wpp-list-with-thumbnails li img {
    width: auto;
    padding-right: 5px;
    max-height: none !important;
}

.wpp-list.wpp-list-with-thumbnails li a:first-child{
	float: left;
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: fit-content;
    width: 35%;
	min-height: auto;
}

.wpp-list.wpp-list-with-thumbnails li a:last-child{
    font-size: 18px;
    overflow: hidden;
    display: block;
    width: 65%;
	height:auto;
	background: none;
    color: #000;
	line-height:24px;
	font-family: 'Libre Baskerville', serif;
    line-height: 25px;
    font-weight: normal;
}

.wpp-list.wpp-list-with-thumbnails{
	background: #fff;
    overflow: hidden;
}

span.widget-title {
    text-align: center;
    text-transform: uppercase;
}


@media screen and (max-width: 768px) {
	.wpp-list.wpp-list-with-thumbnails li a:last-child{
