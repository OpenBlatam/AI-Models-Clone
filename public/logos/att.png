                text-align: center;
                padding-bottom: 15px;
                padding-top: 14px;
                padding-right: 13px;
                text-shadow: rgba(255,255,255,0.65) 0px 1px;
                filter: Shadow(Color=#fff, Direction=90, Strength=1);
