[flake8]
# Maximum line length
max-line-length = 127

# Exclude patterns
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    env,
    build,
    dist,
    *.egg-info,
    migrations,
    .pytest_cache,
    .coverage,
    htmlcov

# Ignore specific error codes
ignore =
    E203,  # whitespace before ':'
    E266,  # too many leading '#' for block comment
    E501,  # line too long (handled by max-line-length)
    W503,  # line break before binary operator
    F401,  # imported but unused (handled by isort)
    F403,  # star imports (sometimes needed)
    F405,  # name may be undefined (false positives)

# Per-file ignores
per-file-ignores =
    __init__.py:F401,F403
    tests/*:E501,F401

# Maximum complexity
max-complexity = 10

# Show source
show-source = True

# Statistics
statistics = True

# Count errors
count = True

# Select errors
select = E,F,W,C

# Exclude from complexity checks
exclude-complexity =
    tests/*




